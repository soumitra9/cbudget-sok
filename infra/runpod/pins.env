# Pinned versions for runpod/pytorch:1.0.2-cu1281-torch280-ubuntu2404 (driver 570, CUDA 12.8).
# Do NOT install vllm into the cbudget uv venv: default vllm wheels pull torch cu129/cu130
# and break on this image. Use VLLM_ENV instead (inherits system torch 2.8+cu128).

POD_IMAGE="runpod/pytorch:1.0.2-cu1281-torch280-ubuntu2404"
VLLM_ENV="/root/vllm_env"
VLLM_VERSION="0.8.5.post1"
TRANSFORMERS_SPEC=">=4.45,<4.53"
CBUDGET_DIR="/workspace/cbudget"
RTK_PINNED_COMMIT="5d32d0736f686b69d1e8b9dc45c007d4eb77a0a2"
# Pin harness code to this git SHA (update on each release push).
CBUDGET_REPO_REF="d3742bd"
