{
  "schema_version": "1.0",
  "event_types": [
    "run_started",
    "model_request",
    "model_response",
    "tool_request",
    "tool_result",
    "compaction_call",
    "compaction_started",
    "compaction_completed",
    "grader_result",
    "run_completed",
    "run_failed"
  ],
  "required_fields": {
    "common": ["schema_version", "run_id", "event_id", "event_type", "timestamp"],
    "run_started": ["task_id", "seed"],
    "model_request": [
      "turn",
      "prompt_hash",
      "prompt_tokens_serialized",
      "occupancy",
      "regions",
      "treatment",
      "model"
    ],
    "model_response": ["turn", "generated_tokens", "finish_reason"],
    "tool_request": ["turn", "original_command"],
    "tool_result": [
      "turn",
      "original_command",
      "executed_command",
      "rtk_supported",
      "fallback_used",
      "exit_code",
      "output_tokens"
    ],
    "compaction_call": ["turn", "prompt_tokens", "generated_tokens", "cost_usd_simulated"],
    "compaction_started": ["turn"],
    "compaction_completed": ["turn", "input_tokens", "output_tokens", "fact_probe_result"],
    "grader_result": ["success", "exit_code", "stdout_tail"],
    "run_completed": ["status", "total_serialized_pt", "total_gt", "peak_occupancy", "task_success"],
    "run_failed": ["failure_state", "message", "retry_eligible"]
  },
  "regions": [
    "system",
    "task",
    "tool_schema",
    "history_reasoning",
    "history_tool_output",
    "history_final"
  ]
}
